PORT=3003
NODE_ENV=development

# LLM (Ollama on same host or remote URL)
OLLAMA_URL=http://localhost:11434
MODEL_NAME=llama3.1
EMBEDDING_MODEL=Xenova/all-MiniLM-L6-v2

# Supabase — required when AI_REQUIRE_AUTH=true
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_VECTOR_RPC=match_kb_chunks

# Phase 3 — Web search (Tavily)
TAVILY_API_KEY=

# Phase 5 — Production security
# Local dev: keep false. Production (Render/Railway): set true
AI_REQUIRE_AUTH=false
AI_RATE_LIMIT=40
AI_RATE_WINDOW_MS=60000

# Comma-separated browser origins for web app CORS (optional)
# React Native requests usually have no Origin header.
# CORS_ORIGINS=https://www.alphafreightuk.com,https://alphafreightuk.com
