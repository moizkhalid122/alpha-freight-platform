{
  "rules": {
    "loads": {
      ".read": true,
      ".write": true,
      ".indexOn": ["supplierId", "carrierId", "status"],
      "$loadId": {
        ".read": true,
        ".write": true
      }
    },
    "vehicles": {
      ".read": true,
      ".write": true
    },
    "users": {
      ".read": true,
      ".write": true,
      "$userId": {
        ".read": true,
        ".write": true
      }
    },
    "suppliers": {
      ".read": true,
      ".write": true,
      ".indexOn": ["email"],
      "$supplierId": {
        ".read": true,
        ".write": true
      }
    },
    "carriers": {
      ".read": true,
      ".write": true,
      ".indexOn": ["email"],
      "$carrierId": {
        ".read": true,
        ".write": true
      }
    },
    "appeals": {
      ".read": true,
      ".write": true,
      "$appealId": {
        ".read": true,
        ".write": true
      }
    },
    "messages": {
      ".read": true,
      ".write": true,
      ".indexOn": ["recipientId", "senderId", "carrierId", "supplierId"],
      "$userId": {
        ".read": true,
        ".write": true,
        "$messageId": {
          ".read": true,
          ".write": true
        }
      }
    },
    "notifications": {
      ".read": true,
      ".write": true,
      ".indexOn": ["user_id", "user_type", "read"],
      "$notificationId": {
        ".read": true,
        ".write": true
      }
    },
    "driverLocations": {
      ".read": true,
      ".write": true,
      "$driverId": {
        ".read": true,
        ".write": true
      }
    },
    "loadLocations": {
      ".read": true,
      ".write": true,
      "$loadId": {
        ".read": true,
        ".write": true,
        "$driverId": {
          ".read": true,
          ".write": true
        }
      }
    },
    "social": {
      "users": { ".read": true, ".write": true },
      "posts": { ".read": true, ".write": true },
      "notifications": { ".read": true, ".write": true },
      "comments": { ".read": true, ".write": true }
    },
    "payments": {
      ".read": true,
      ".write": true,
      "$paymentId": {
        ".read": true,
        ".write": true
      }
    },
    "withdrawals": {
      ".read": true,
      ".write": true,
      "$withdrawalId": {
        ".read": true,
        ".write": true
      }
    },
    "wallets": {
      ".read": true,
      ".write": true,
      "$carrierId": {
        ".read": true,
        ".write": true
      }
    },
    "carrierBankDetails": {
      ".read": true,
      ".write": true,
      "$carrierId": {
        ".read": true,
        ".write": true
      }
    },
    "carrierWithdrawals": {
      ".read": true,
      ".write": true,
      "$carrierId": {
        ".read": true,
        ".write": true,
        "$withdrawalId": {
          ".read": true,
          ".write": true
        }
      }
    },
    "payLetterPending": {
      ".read": true,
      ".write": true,
      ".indexOn": ["supplierId", "status", "loadId"],
      "$orderId": {
        ".read": true,
        ".write": true
      }
    }
  }
}

